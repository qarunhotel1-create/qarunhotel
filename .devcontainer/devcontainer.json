{
    "name": "QARUN HOTEL Environment",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "features": {
        "ghcr.io/devcontainers/features/sqlite3:1": {}
    },
    "postCreateCommand": "bash .devcontainer/postCreateCommand.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    },
    "forwardPorts": [5000],
    "portsAttributes": {
        "5000": {
            "label": "QARUN HOTEL Website",
            "onAutoForward": "openBrowser"
        }
    }
}
