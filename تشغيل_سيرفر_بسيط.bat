@echo off
chcp 65001 > nul
title فندق قارون - سيرفر بسيط
color 0A

echo ================================================
echo         مرحباً بك في نظام فندق قارون
echo         تشغيل سيرفر بسيط على الشبكة المحلية
echo ================================================
echo.

:: عرض عنوان IP المحلي
echo جاري الحصول على عنوان IP المحلي...
for /f "tokens=2 delims=:" %%a in ('ipconfig ^| findstr /c:"IPv4"') do (
    set IP=%%a
    goto :found_ip
)

:found_ip
set IP=%IP:~1%

echo.
echo ================================================
echo تشغيل السيرفر على الشبكة المحلية
echo.
echo يمكن الوصول للنظام محلياً عبر: http://localhost:5000
echo يمكن الوصول للنظام من أجهزة أخرى عبر: http://%IP%:5000
echo.
echo بيانات الدخول الافتراضية للمدير:
echo اسم المستخدم: admin@example.com
echo كلمة المرور: admin123
echo ================================================
echo.

:: تشغيل التطبيق مباشرة
python run.py

pause